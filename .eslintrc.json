{
  "env": {
    "browser": true,
    "es2020": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }]
  },
  "globals": {
    "firebase": "readonly",
    "lucide": "readonly",
    "L": "readonly",
    "navigator": "readonly",
    "localStorage": "readonly",
    "fetch": "readonly"
  }
}
